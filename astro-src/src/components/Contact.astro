---
import { site } from "../data/site";
import Icon from "./Icon.astro";
import WhatsAppIcon from "./WhatsAppIcon.astro";

const items = [
  { icon: "phone", label: "Teléfono / WhatsApp", value: site.phone, href: `tel:+51${site.phoneRaw}` },
  { icon: "mail", label: "Correo", value: site.email, href: `mailto:${site.email}` },
  { icon: "clock", label: "Horario", value: `${site.hours} · ${site.hoursSat}`, href: null },
];
---

<section class="section" id="contacto">
  <div class="container contact__grid">
    <div class="contact__info">
      <span class="eyebrow">Contacto</span>
      <h2>Conversemos sobre tu negocio</h2>
      <p class="contact__lead">Déjanos tus datos y te contactamos por WhatsApp para agendar tu asesoría gratuita.</p>

      <ul class="contact__list">
        {items.map((it) => (
          <li>
            <div class="icon-box"><Icon name={it.icon} /></div>
            <div>
              <span class="contact__label">{it.label}</span>
              {it.href ? (
                <a class="contact__value" href={it.href}>{it.value}</a>
              ) : (
                <span class="contact__value">{it.value}</span>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="contact__form-wrap reveal">
      <form class="contact__form" data-wa-form data-wa={site.whatsapp} novalidate>
        <h3>Solicita tu asesoría gratuita</h3>
        <label>
          Nombre
          <input type="text" name="name" placeholder="Tu nombre" autocomplete="name" />
          <span class="field-error" data-error></span>
        </label>
        <label>
          Celular
          <input type="tel" name="phone" placeholder="9XX XXX XXX" inputmode="numeric" autocomplete="tel" />
          <span class="field-error" data-error></span>
        </label>
        <label>
          ¿En qué te ayudamos?
          <textarea name="message" rows="3" placeholder="Ej: Necesito llevar la contabilidad de mi empresa"></textarea>
          <span class="field-error" data-error></span>
        </label>
        <button class="btn btn--wa" type="submit" style="width:100%">
          <WhatsAppIcon />
          Enviar por WhatsApp
        </button>
        <p class="form-status" data-form-status role="status" aria-live="polite"></p>
        <p class="form-note">Respuesta el mismo día hábil. Tus datos no se comparten con terceros.</p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 48px;
    align-items: start;
  }
  .contact__info,
  .contact__form-wrap {
    min-width: 0;
  }
  .contact__lead {
    color: var(--gray-500);
    margin: 14px 0 28px;
    max-width: 420px;
  }
  .contact__list {
    display: grid;
    gap: 18px;
  }
  .contact__list li {
    display: flex;
    align-items: center;
    gap: 16px;
    min-width: 0;
  }
  .contact__list li > div:last-child {
    min-width: 0;
  }
  .contact__label {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-400);
    font-weight: 600;
  }
  .contact__value {
    font-weight: 600;
    color: var(--navy);
    overflow-wrap: anywhere;
  }
  a.contact__value:hover {
    color: var(--blue);
  }

  .contact__form {
    background: #fff;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 30px 28px;
    display: grid;
    gap: 14px;
  }
  .contact__form h3 {
    font-size: 1.25rem;
    margin-bottom: 4px;
  }
  .contact__form label {
    display: grid;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink);
  }
  .contact__form input,
  .contact__form textarea {
    width: 100%;
    min-width: 0;
    font-family: inherit;
    font-size: 0.98rem;
    padding: 12px 14px;
    border: 1.5px solid var(--gray-200);
    border-radius: 10px;
    background: var(--gray-50);
    color: var(--ink);
    resize: vertical;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .contact__form input:focus,
  .contact__form textarea:focus {
    outline: none;
    border-color: var(--blue);
    background: #fff;
  }
  .contact__form [aria-invalid="true"] {
    border-color: #e5484d;
    background: #fff5f5;
  }
  .field-error {
    color: #e5484d;
    font-size: 0.78rem;
    font-weight: 500;
    min-height: 0;
  }
  .form-status {
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--blue);
    min-height: 1.2em;
  }
  .form-note {
    font-size: 0.78rem;
    color: var(--gray-400);
    text-align: center;
  }

  @media (max-width: 820px) {
    .contact__grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 32px;
    }
  }
</style>
