---
import { site } from "../data/site";
import Icon from "./Icon.astro";

const items = [
  { icon: "phone", label: "Teléfono / WhatsApp", value: site.phone, href: `tel:+51${site.phoneRaw}` },
  { icon: "mail", label: "Correo", value: site.email, href: `mailto:${site.email}` },
  { icon: "pin", label: "Oficina", value: `${site.address}, S.J.M. — Ref.: ${site.addressRef}`, href: null },
  { icon: "clock", label: "Horario", value: `${site.hours} · ${site.hoursSat}`, href: null },
];
---

<section class="section" id="contacto">
  <div class="container contact__grid">
    <div class="contact__info">
      <span class="eyebrow">Contacto</span>
      <h2>Conversemos sobre tu negocio</h2>
      <p class="contact__lead">Déjanos tus datos y te contactamos por WhatsApp para agendar tu asesoría gratuita.</p>

      <ul class="contact__list">
        {items.map((it) => (
          <li>
            <div class="icon-box"><Icon name={it.icon} /></div>
            <div>
              <span class="contact__label">{it.label}</span>
              {it.href ? (
                <a class="contact__value" href={it.href}>{it.value}</a>
              ) : (
                <span class="contact__value">{it.value}</span>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="contact__form-wrap reveal">
      <form class="contact__form" data-wa-form data-wa={site.whatsapp} novalidate>
        <h3>Solicita tu asesoría gratuita</h3>
        <label>
          Nombre
          <input type="text" name="name" placeholder="Tu nombre" autocomplete="name" />
          <span class="field-error" data-error></span>
        </label>
        <label>
          Celular
          <input type="tel" name="phone" placeholder="9XX XXX XXX" inputmode="numeric" autocomplete="tel" />
          <span class="field-error" data-error></span>
        </label>
        <label>
          ¿En qué te ayudamos?
          <textarea name="message" rows="3" placeholder="Ej: Necesito llevar la contabilidad de mi empresa"></textarea>
          <span class="field-error" data-error></span>
        </label>
        <button class="btn btn--wa" type="submit" style="width:100%">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-1.6-.8-2.6-1.4-3.7-3.2-.3-.5.3-.5.8-1.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.3 5.2 4.6 2 .8 2.7.9 3.7.8.6-.1 1.7-.7 2-1.4.2-.6.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2z"/></svg>
          Enviar por WhatsApp
        </button>
        <p class="form-status" data-form-status role="status" aria-live="polite"></p>
        <p class="form-note">Respuesta el mismo día hábil. Tus datos no se comparten con terceros.</p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .contact__lead {
    color: var(--gray-500);
    margin: 14px 0 28px;
    max-width: 420px;
  }
  .contact__list {
    display: grid;
    gap: 18px;
  }
  .contact__list li {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .contact__label {
    display: block;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray-400);
    font-weight: 600;
  }
  .contact__value {
    font-weight: 600;
    color: var(--navy);
  }
  a.contact__value:hover {
    color: var(--blue);
  }

  .contact__form {
    background: #fff;
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 30px 28px;
    display: grid;
    gap: 14px;
  }
  .contact__form h3 {
    font-size: 1.25rem;
    margin-bottom: 4px;
  }
  .contact__form label {
    display: grid;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink);
  }
  .contact__form input,
  .contact__form textarea {
    font-family: inherit;
    font-size: 0.98rem;
    padding: 12px 14px;
    border: 1.5px solid var(--gray-200);
    border-radius: 10px;
    background: var(--gray-50);
    color: var(--ink);
    resize: vertical;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .contact__form input:focus,
  .contact__form textarea:focus {
    outline: none;
    border-color: var(--blue);
    background: #fff;
  }
  .contact__form [aria-invalid="true"] {
    border-color: #e5484d;
    background: #fff5f5;
  }
  .field-error {
    color: #e5484d;
    font-size: 0.78rem;
    font-weight: 500;
    min-height: 0;
  }
  .form-status {
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--blue);
    min-height: 1.2em;
  }
  .form-note {
    font-size: 0.78rem;
    color: var(--gray-400);
    text-align: center;
  }

  @media (max-width: 820px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
