---
import {
  ArrowRight,
  BadgeCheck,
  CalendarClock,
  ChartNoAxesCombined,
  Check,
  CircleCheck,
  Clock3,
  Cog,
  Files,
  Handshake,
  Mail,
  Phone,
  ReceiptText,
  RefreshCw,
  ShieldCheck,
  UserRound,
  UsersRound,
} from "@lucide/astro";

interface Props {
  name: string;
  class?: string;
  cls?: string;
}

const { name, class: className, cls } = Astro.props;
const finalCls = className ?? cls ?? "";

const icons = {
  arrow: ArrowRight,
  badge: BadgeCheck,
  calendar: CalendarClock,
  chart: ChartNoAxesCombined,
  check: Check,
  clock: Clock3,
  docs: Files,
  gear: Cog,
  handshake: Handshake,
  mail: Mail,
  payroll: UsersRound,
  person: UserRound,
  phone: Phone,
  refund: RefreshCw,
  shield: ShieldCheck,
  tax: ReceiptText,
};

const SelectedIcon = icons[name as keyof typeof icons] ?? CircleCheck;
---

<SelectedIcon class={finalCls} aria-hidden="true" stroke-width={1.8} />
