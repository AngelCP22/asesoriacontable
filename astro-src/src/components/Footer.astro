---
import { site, nav, services, waLink } from "../data/site";
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <img src={`${base}assets/logo-mark.svg`} alt={site.legalName} width="52" height="52" />
      <p class="footer__name">{site.legalName}</p>
      <p class="footer__desc">
        Soluciones contables, tributarias y laborales que impulsan tu negocio con
        confianza, experiencia y cercanía.
      </p>
      <div class="footer__social">
        <a href={site.social.facebook} aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 22v-8h3l1-4h-4V8c0-1 .3-1.7 1.8-1.7H17V2.8C16.4 2.7 15.3 2.6 14 2.6c-2.7 0-4.5 1.6-4.5 4.7V10H6v4h3.5v8H13z"/></svg></a>
        <a href={site.social.instagram} aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
        <a href={site.social.linkedin} aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 5a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM3 8.5h3.8V22H3V8.5zM9 8.5h3.6v1.8h.05c.5-.9 1.7-1.9 3.6-1.9 3.8 0 4.5 2.5 4.5 5.8V22h-3.8v-6c0-1.4 0-3.2-2-3.2s-2.3 1.5-2.3 3.1V22H9V8.5z"/></svg></a>
      </div>
    </div>

    <div class="footer__col">
      <h4>Enlaces</h4>
      <ul>
        {nav.map((n) => <li><a href={n.href}>{n.label}</a></li>)}
      </ul>
    </div>

    <div class="footer__col">
      <h4>Servicios</h4>
      <ul>
        {services.slice(0, 5).map((s) => <li><a href="#servicios">{s.title}</a></li>)}
      </ul>
    </div>

    <div class="footer__col">
      <h4>Contacto</h4>
      <ul class="footer__contact">
        <li><a href={`tel:+51${site.phoneRaw}`}>{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li>{site.hours}</li>
        <li>{site.hoursSat}</li>
      </ul>
      <a class="btn btn--wa footer__wa" href={waLink} target="_blank" rel="noopener">Escríbenos</a>
    </div>
  </div>

  <div class="footer__bar">
    <div class="container footer__bar-inner">
      <span>© {year} {site.legalName}. Todos los derechos reservados.</span>
      <span class="footer__legal">
        <a href={`${base}privacidad/`}>Política de Privacidad</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #061e4a;
    color: #b9c8e6;
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.3fr;
    gap: 40px;
    padding: 60px 0 44px;
  }
  .footer__brand img {
    background: #fff;
    border-radius: 12px;
    padding: 6px;
  }
  .footer__name {
    color: #fff;
    font-weight: 700;
    margin: 14px 0 8px;
  }
  .footer__desc {
    font-size: 0.9rem;
    max-width: 300px;
    line-height: 1.7;
  }
  .footer__social {
    display: flex;
    gap: 10px;
    margin-top: 18px;
  }
  .footer__social a {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    transition: background 0.2s ease;
  }
  .footer__social a:hover {
    background: var(--blue);
  }
  .footer__social svg {
    width: 18px;
    height: 18px;
  }

  .footer__col h4 {
    color: #fff;
    font-size: 0.98rem;
    margin-bottom: 16px;
  }
  .footer__col ul {
    display: grid;
    gap: 10px;
  }
  .footer__col a {
    font-size: 0.9rem;
    transition: color 0.15s ease;
  }
  .footer__col a:hover {
    color: #fff;
  }
  .footer__contact li {
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .footer__wa {
    margin-top: 18px;
    padding: 10px 20px;
    font-size: 0.88rem;
  }

  .footer__bar {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .footer__bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    padding: 20px 0;
    font-size: 0.83rem;
  }
  .footer__legal a:hover {
    color: #fff;
  }

  @media (max-width: 860px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
  @media (max-width: 520px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
    .footer__bar-inner {
      justify-content: center;
      text-align: center;
    }
  }
</style>
