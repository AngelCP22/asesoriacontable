---
import { testimonials } from "../data/site";
---

<section class="section" id="resenas">
  <div class="container">
    <div class="testi__head">
      <div class="section-head" style="margin-bottom:0">
        <span class="eyebrow">Reseñas</span>
        <h2>Lo que dicen nuestros clientes</h2>
      </div>
    </div>

    <div class="testi__grid">
      {testimonials.map((t) => (
        <figure class="card testi reveal">
          <div class="testi__stars">★★★★★</div>
          <blockquote>“{t.text}”</blockquote>
          <figcaption>
            <span class="testi__avatar">{t.name.charAt(0)}</span>
            <span>
              <strong>{t.name}</strong>
              <em>{t.role}</em>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testi__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 40px;
  }
  .testi__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .testi {
    padding: 28px 26px;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .testi:hover {
    box-shadow: var(--shadow);
  }
  .testi__stars {
    color: #ffc531;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .testi blockquote {
    margin: 0;
    color: var(--ink);
    font-size: 0.98rem;
    flex-grow: 1;
  }
  .testi figcaption {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid var(--gray-100);
  }
  .testi__avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, var(--navy), var(--blue));
    color: #fff;
    font-weight: 700;
  }
  .testi figcaption strong {
    display: block;
    font-size: 0.95rem;
  }
  .testi figcaption em {
    font-style: normal;
    font-size: 0.85rem;
    color: var(--gray-500);
  }

  @media (max-width: 900px) {
    .testi__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
