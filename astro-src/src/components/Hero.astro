---
import fs from "node:fs";
import { site, waLink } from "../data/site";

const base = import.meta.env.BASE_URL;

// Foto real del contador: colocar el archivo en public/assets/ con uno de
// estos nombres y el sitio la usa automáticamente en el próximo build.
const photoCandidates = ["contador.webp", "contador.jpg", "contador.png"];
const found = photoCandidates.find((f) => fs.existsSync(`public/assets/${f}`));
const photoSrc = `${base}assets/${found ?? "contador-placeholder.svg"}`;

const bullets = [
  "Cumplimiento 100% garantizado",
  "Atención personalizada",
  "Respuestas rápidas y efectivas",
];

const waCotiza = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(
  "Hola, me gustaría solicitar una cotización para mi empresa."
)}`;
---

<section class="hero" id="inicio">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container hero__grid">
    <div class="hero__visual">
      <img
        class="hero__photo"
        src={photoSrc}
        alt={`Contador de ${site.name} listo para asesorarte`}
        width="520"
        height="620"
        loading="eager"
        fetchpriority="high"
      />
      <div class="float-card">
        <span class="float-card__eyebrow">Más de</span>
        <strong class="float-card__value">150+</strong>
        <span class="float-card__label">Empresas confían<br />en nosotros</span>
        <span class="float-card__stars" aria-hidden="true">★★★★★</span>
        <span class="float-card__rating">{site.rating}/5 en Google</span>
      </div>
    </div>

    <div class="hero__copy">
      <span class="hero__pill">Asesoría experta. Cumplimiento total. Tranquilidad para crecer.</span>
      <h1>
        Soluciones contables,<br />
        <span class="accent">tributarias y laborales</span><br />
        para hacer crecer tu negocio
      </h1>
      <p class="hero__lead">
        Acompañamos a empresas y emprendedores con asesoría integral en
        contabilidad, impuestos, laboral y constitución de empresas.
        Cumplimos contigo, para que tú te enfoques en lo que importa.
      </p>

      <ul class="hero__checks">
        {bullets.map((b) => (
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {b}
          </li>
        ))}
      </ul>

      <div class="hero__actions">
        <a class="btn btn--navy" href="#contacto">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 5h14a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1zM4 9h16M8 3v4M16 3v4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Agenda una consulta
        </a>
        <a class="btn btn--ghost" href={waCotiza} target="_blank" rel="noopener">Cotiza ahora</a>
        <a class="btn btn--wa-outline" href={waLink} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-1.6-.8-2.6-1.4-3.7-3.2-.3-.5.3-.5.8-1.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.3 5.2 4.6 2 .8 2.7.9 3.7.8.6-.1 1.7-.7 2-1.4.2-.6.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2z"/></svg>
          Hablar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--gray-50);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(1100px 520px at 88% -8%, rgba(31, 94, 255, 0.14), transparent 60%),
      radial-gradient(760px 420px at 8% 110%, rgba(8, 43, 102, 0.08), transparent 60%);
    pointer-events: none;
  }
  .hero__grid {
    position: relative;
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 48px;
    align-items: center;
    padding: 60px 0 70px;
  }

  .hero__pill {
    display: inline-block;
    padding: 8px 18px;
    border-radius: 999px;
    border: 1px solid rgba(31, 94, 255, 0.25);
    background: rgba(31, 94, 255, 0.07);
    color: var(--blue);
    font-size: 0.82rem;
    font-weight: 500;
  }
  .hero__copy h1 {
    font-size: clamp(2rem, 4.4vw, 3.1rem);
    margin: 18px 0 0;
    line-height: 1.15;
  }
  .accent {
    color: var(--blue);
  }
  .hero__lead {
    margin-top: 20px;
    color: var(--gray-500);
    font-size: 1.08rem;
    max-width: 560px;
  }

  .hero__checks {
    display: grid;
    gap: 12px;
    margin-top: 24px;
  }
  .hero__checks li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 500;
    color: var(--ink);
  }
  .hero__checks svg {
    width: 22px;
    height: 22px;
    padding: 4px;
    border-radius: 50%;
    background: rgba(31, 94, 255, 0.12);
    color: var(--blue);
    flex-shrink: 0;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }
  .btn--navy {
    background: var(--navy);
    color: #fff;
  }
  .btn--navy:hover {
    background: var(--navy-700);
    color: #fff;
  }
  .btn--navy svg {
    width: 18px;
    height: 18px;
  }
  .btn--wa-outline {
    background: #fff;
    border: 1.5px solid var(--wa);
    color: var(--wa-600);
  }
  .btn--wa-outline:hover {
    background: var(--wa);
    color: #fff;
  }
  .btn--wa-outline svg {
    width: 18px;
    height: 18px;
  }

  /* Visual: foto + tarjeta flotante */
  .hero__visual {
    position: relative;
  }
  .hero__photo {
    display: block;
    width: 100%;
    max-width: 440px;
    height: auto;
    margin-inline: auto;
    border-radius: 24px;
    box-shadow: var(--shadow-lg);
    object-fit: cover;
    background: #dfe9fb;
  }
  .float-card {
    position: absolute;
    right: -8px;
    bottom: 26px;
    z-index: 2;
    display: grid;
    justify-items: center;
    gap: 2px;
    background: #fff;
    border-radius: 16px;
    padding: 16px 22px;
    box-shadow: var(--shadow-lg);
    text-align: center;
  }
  .float-card__eyebrow {
    font-size: 0.72rem;
    color: var(--gray-400);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .float-card__value {
    font-size: 1.9rem;
    line-height: 1;
    color: var(--blue);
    font-weight: 700;
  }
  .float-card__label {
    font-size: 0.78rem;
    color: var(--gray-500);
    line-height: 1.3;
  }
  .float-card__stars {
    color: #ffc531;
    letter-spacing: 2px;
    font-size: 0.9rem;
    margin-top: 4px;
  }
  .float-card__rating {
    font-size: 0.72rem;
    color: var(--gray-400);
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 44px 0 56px;
    }
    .hero__visual {
      order: 2;
      max-width: 440px;
      margin-inline: auto;
      width: 100%;
    }
    .hero__copy {
      order: 1;
      text-align: left;
    }
    .float-card {
      right: 4px;
      bottom: 18px;
    }
  }
  @media (max-width: 520px) {
    .hero__actions .btn {
      width: 100%;
      justify-content: center;
    }
    .float-card {
      padding: 12px 16px;
    }
  }
</style>
