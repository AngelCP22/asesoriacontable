---
import { site, nav, waLink } from "../data/site";
const base = import.meta.env.BASE_URL;
---

<header class="header" data-header>
  <!-- Barra superior -->
  <div class="topbar">
    <div class="container topbar__inner">
      <span class="topbar__item">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 5a1 1 0 0 1 1-1h3l1.5 4-2 1.5a11 11 0 0 0 5 5l1.5-2 4 1.5V18a1 1 0 0 1-1 1A15 15 0 0 1 4 5z"/></svg>
        {site.phone}
      </span>
      <span class="topbar__sep">·</span>
      <span class="topbar__item">{site.hours}</span>
    </div>
  </div>

  <!-- Navegación -->
  <div class="navbar">
    <div class="container navbar__inner">
      <a class="brand" href="#inicio" aria-label={site.legalName}>
        <img src={`${base}assets/logo.svg`} alt={site.legalName} width="200" height="53" />
      </a>

      <nav class="nav" aria-label="Principal">
        {nav.map((item) => (
          <a class="nav__link" href={item.href} data-nav-link>{item.label}</a>
        ))}
      </nav>

      <div class="navbar__cta">
        <a class="btn btn--primary" href={waLink} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-1.6-.8-2.6-1.4-3.7-3.2-.3-.5.3-.5.8-1.5.1-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.3 5.2 4.6 2 .8 2.7.9 3.7.8.6-.1 1.7-.7 2-1.4.2-.6.2-1.2.2-1.4-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2z"/></svg>
          Agenda una asesoría
        </a>
      </div>

      <button class="burger" data-menu-toggle aria-expanded="false" aria-controls="menu-panel" aria-label="Abrir menú">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Panel móvil -->
  <div class="menu-panel" id="menu-panel" data-menu-panel>
    <nav class="menu-panel__nav" aria-label="Móvil">
      {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="btn btn--wa" href={waLink} target="_blank" rel="noopener" style="width:100%">Agenda por WhatsApp</a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 80;
    background: #fff;
    transition: box-shadow 0.25s ease;
  }
  .header.is-scrolled {
    box-shadow: 0 6px 24px rgba(8, 43, 102, 0.08);
  }

  .topbar {
    background: var(--navy);
    color: #cfe0ff;
    font-size: 0.82rem;
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: flex-end;
    height: 40px;
  }
  .topbar__item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .topbar__sep {
    opacity: 0.5;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 78px;
    gap: 20px;
  }
  .brand img {
    height: 48px;
    width: auto;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
  }
  .nav__link {
    padding: 8px 14px;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--ink);
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav__link:hover,
  .nav__link.is-active {
    color: var(--blue);
    background: var(--gray-50);
  }

  .navbar__cta {
    display: flex;
  }
  .navbar__cta .btn {
    padding: 11px 20px;
    font-size: 0.9rem;
  }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .burger span {
    width: 26px;
    height: 2.5px;
    background: var(--navy);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }
  .burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  .menu-panel {
    display: none;
    flex-direction: column;
    gap: 16px;
    padding: 8px 20px 24px;
    border-top: 1px solid var(--gray-100);
  }
  .menu-panel.is-open {
    display: flex;
  }
  .menu-panel__nav {
    display: flex;
    flex-direction: column;
  }
  .menu-panel__nav a {
    padding: 13px 6px;
    font-weight: 500;
    border-bottom: 1px solid var(--gray-100);
  }
  :global(body.no-scroll) {
    overflow: hidden;
  }

  @media (max-width: 940px) {
    .nav,
    .navbar__cta {
      display: none;
    }
    .burger {
      display: flex;
    }
  }
</style>
