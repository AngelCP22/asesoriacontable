---
import { trustbar } from "../data/site";
import Icon from "./Icon.astro";
---

<section class="trust">
  <div class="container trust__grid">
    {trustbar.map((t) => (
      <div class="trust__item reveal">
        <Icon name={t.icon} cls="trust__icon" />
        <div>
          <strong class="trust__title">{t.title}</strong>
          <span class="trust__label">{t.label}</span>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .trust {
    background: var(--navy);
    color: #fff;
  }
  .trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    padding: 26px 0;
  }
  .trust__item {
    display: flex;
    align-items: center;
    gap: 14px;
    justify-content: center;
    position: relative;
  }
  .trust__item:not(:last-child)::after {
    content: "";
    position: absolute;
    right: -10px;
    top: 12%;
    height: 76%;
    width: 1px;
    background: rgba(255, 255, 255, 0.14);
  }
  .trust__item :global(.trust__icon) {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    color: var(--blue-light);
  }
  .trust__title {
    display: block;
    font-size: 0.98rem;
    line-height: 1.25;
  }
  .trust__label {
    display: block;
    font-size: 0.82rem;
    color: #cfe0ff;
  }
  @media (max-width: 900px) {
    .trust__grid {
      grid-template-columns: 1fr 1fr;
      gap: 22px 12px;
    }
    .trust__item {
      justify-content: flex-start;
    }
    .trust__item:nth-child(2)::after {
      display: none;
    }
  }
  @media (max-width: 480px) {
    .trust__grid {
      grid-template-columns: 1fr;
    }
    .trust__item::after {
      display: none !important;
    }
  }
</style>
