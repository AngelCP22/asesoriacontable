---
import { services, waLink } from "../data/site";
import Icon from "./Icon.astro";
---

<section class="section section--gray" id="servicios">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Procesos contables inteligentes</span>
      <h2>Automatizamos para reducir tiempos y costos</h2>
      <p>Convertimos tareas repetitivas en procesos digitales, con preliminares de impuestos, controles y reportes para que gestiones con anticipación.</p>
    </div>

    <div class="services__grid">
      {services.map((s) => (
        <article class="card service reveal">
          <div class="icon-box"><Icon name={s.icon} /></div>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
          <span class="service__benefit"><Icon name="check" />{s.benefit}</span>
          <a class="service__link" href={waLink} target="_blank" rel="noopener">
            Conocer solución
            <Icon name="arrow" cls="service__arrow" />
          </a>
        </article>
      ))}
    </div>

    <div class="services__cta">
      <a class="btn btn--ghost" href={waLink} target="_blank" rel="noopener">Ver todos los servicios</a>
    </div>
  </div>
</section>

<style>
  .services__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 18px;
  }
  .services__cta {
    display: flex;
    justify-content: center;
    margin-top: 30px;
  }
  .service {
    padding: 24px 22px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .service:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: transparent;
  }
  .service h3 {
    font-size: 1.08rem;
    margin: 16px 0 8px;
  }
  .service p {
    color: var(--gray-500);
    font-size: 0.92rem;
    flex-grow: 1;
  }
  .service__benefit {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: 16px;
    color: var(--navy);
    font-size: 0.8rem;
    font-weight: 600;
  }
  .service__benefit :global(svg) {
    width: 18px;
    height: 18px;
    padding: 3px;
    border-radius: 50%;
    background: rgba(31, 94, 255, 0.1);
    color: var(--blue);
    flex-shrink: 0;
  }
  .service__link {
    margin-top: 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--blue);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .service__link :global(.service__arrow) {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }
  .service__link:hover :global(.service__arrow) {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .services__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .services__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
