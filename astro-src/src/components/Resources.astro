---
import { resources, waLink } from "../data/site";

const base = import.meta.env.BASE_URL;
---

<section class="section section--gray" id="recursos">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">Recursos y artículos</span>
      <h2>Contenido que te ayuda a crecer</h2>
      <p>Novedades tributarias, contables y laborales explicadas simple.</p>
    </div>

    <div class="res__grid">
      {resources.map((r) => (
        <article class="card res reveal">
          <div class="res__thumb">
            <img src={`${base}${r.img}`} alt="" width="400" height="220" loading="lazy" />
            <span class="res__tag">{r.tag}</span>
          </div>
          <div class="res__body">
            <span class="res__date">{r.date}</span>
            <h3>{r.title}</h3>
            <p>{r.text}</p>
            <a class="res__link" href={waLink} target="_blank" rel="noopener">Leer más →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .res__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .res {
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .res:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .res__thumb {
    height: 150px;
    background: linear-gradient(135deg, var(--navy), var(--blue));
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 14px;
  }
  .res__thumb img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .res__tag {
    position: relative;
    z-index: 1;
    background: rgba(255, 255, 255, 0.16);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 5px 12px;
    border-radius: 999px;
  }
  .res__body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .res__date {
    font-size: 0.78rem;
    color: var(--gray-400);
    font-weight: 600;
  }
  .res h3 {
    font-size: 1.08rem;
    margin: 8px 0 10px;
  }
  .res p {
    color: var(--gray-500);
    font-size: 0.92rem;
    flex-grow: 1;
  }
  .res__link {
    margin-top: 16px;
    color: var(--blue);
    font-weight: 600;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .res__grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin-inline: auto;
    }
  }
</style>
