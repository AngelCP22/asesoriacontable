---
import "../styles/global.css";
import { site, waLink } from "../data/site";
import WhatsAppIcon from "../components/WhatsAppIcon.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.legalName,
  description = site.description,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(`${base}assets/logo-mark.svg`, Astro.site).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#082b66" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_PE" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Fuente Poppins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Datos estructurados -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AccountingService",
      name: site.legalName,
      description: site.description,
      telephone: `+51${site.phoneRaw}`,
      email: site.email,
      areaServed: "PE",
      founder: {
        "@type": "Person",
        name: site.accountant.name,
        jobTitle: "Contador Público Colegiado",
      },
      openingHours: ["Mo-Fr 09:00-18:00", "Sa 09:00-13:00"],
    })} />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <slot />

    <!-- WhatsApp flotante -->
    <a
      class="wa-float"
      href={waLink}
      target="_blank"
      rel="noopener"
      aria-label="Escríbenos por WhatsApp"
    >
      <WhatsAppIcon />
    </a>

    <!-- Volver arriba -->
    <button class="to-top" data-to-top aria-label="Volver arriba">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
        ><path d="M18 15l-6-6-6 6" stroke-linecap="round" stroke-linejoin="round"
        ></path></svg
      >
    </button>

    <script>
      import { initMenu } from "../scripts/menu";
      import { initHeaderShadow } from "../scripts/header-shadow";
      import { initFaq } from "../scripts/faq";
      import { initReveal } from "../scripts/reveal";
      import { initToTop } from "../scripts/to-top";
      import { initScrollspy } from "../scripts/scrollspy";
      import { initWhatsappForm } from "../scripts/whatsapp-form";

      const boot = () => {
        for (const init of [
          initMenu,
          initHeaderShadow,
          initFaq,
          initReveal,
          initToTop,
          initScrollspy,
          initWhatsappForm,
        ]) {
          try {
            init();
          } catch (err) {
            console.error("[init]", err);
          }
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot);
      } else {
        boot();
      }
    </script>
  </body>
</html>
